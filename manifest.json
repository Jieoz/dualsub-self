{
  "manifest_version": 3,
  "name": "MyDualsub - 双语字幕 (自带翻译API)",
  "description": "在 YouTube 上显示双语字幕，使用你自己的 OpenAI 兼容翻译 API。翻译不经过任何第三方服务端，密钥仅存本地。",
  "version": "0.5.12",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://m.youtube.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "MyDualsub 设置"
  },
  "content_scripts": [
    {
      "world": "MAIN",
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": [
        "main.js"
      ],
      "run_at": "document_start"
    },
    {
      "world": "ISOLATED",
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": [
        "core.js",
        "isolated.js"
      ],
      "run_at": "document_start"
    }
  ]
}
